  padding: 20px 22px 24px;
  border-right: 1px solid var(--rule-soft);
  position: relative;
}

.pathway:last-child { border-right: none; }

.pathway .num {
  font-family: 'Fraunces', serif;
  font-style: italic;
  font-weight: 300;
  font-size: 56px;
  line-height: 0.9;
  color: var(--accent-risk);
  opacity: 0.85;
}

.pathway .pw-title {
  font-family: 'Noto Serif Thai', serif;
  font-weight: 600;
  font-size: 17px;
  color: var(--ink);
  margin-top: 8px;
  line-height: 1.3;
}

.pathway .pw-method {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.16em;
  color: var(--ink-mute);
  text-transform: uppercase;
  margin-top: 4px;
}

.pathway .pw-body {
  font-size: 13.5px;
  color: var(--ink-soft);
  line-height: 1.55;
  margin-top: 10px;
}

.pathway .pw-funder {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.05em;
  color: var(--accent-good);
  margin-top: 12px;
  padding-top: 10px;
  border-top: 1px dashed var(--rule);
}

/* ─── COLOPHON ───────────────────────────────────────────── */
.colophon {
  margin-top: 48px;
  padding: 22px 0 0;
  border-top: 1px solid var(--rule);
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 36px;
  font-size: 12.5px;
  color: var(--ink-mute);
  font-family: 'Noto Serif Thai', serif;
}

.colophon h4 {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.22em;
  color: var(--ink);
  text-transform: uppercase;
  margin-bottom: 8px;
  font-weight: 500;
}

.colophon p { line-height: 1.6; }
.colophon p + p { margin-top: 6px; }

/* ─── RESPONSIVE ─────────────────────────────────────────── */
@media (max-width: 1080px) {
  .prologue { grid-template-columns: 1fr; gap: 24px; }
  .dim-grid { grid-template-columns: repeat(3, 1fr); }
  .kpi-strip { grid-template-columns: repeat(2, 1fr); }
  .kpi { border-bottom: 1px solid var(--rule); }
