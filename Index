  .masthead .vol, .masthead .date { text-align: center; border-left: none; padding-left: 0; }
}

@media (max-width: 640px) {
  body { padding: 20px 16px 60px; }
  .dim-grid { grid-template-columns: 1fr 1fr; }
  .pathways { grid-template-columns: 1fr; }
