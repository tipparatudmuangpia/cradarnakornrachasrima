<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>C-RADAR · Spatio-Aging Healthcare Atlas · Nakhon Ratchasima Province</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Thai:wght@400;500;600;700&family=Sarabun:wght@300;400;500;600;700&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --paper: #F6F2E9;
  --paper-2: #EDE6D6;
  --ink: #1F1B17;
  --ink-soft: #4A4039;
  --ink-mute: #7A6F65;
  --rule: #C9BFAE;
  --rule-soft: #DDD3BF;
  --accent-risk: #B8442C;
  --accent-risk-soft: #D4775F;
  --accent-warm: #C28A2C;
  --accent-mid: #8A7A3A;
  --accent-good: #3D5C3A;
  --accent-good-soft: #6B8A5C;
  --accent-deep: #2E3B2D;
  --accent-ink: #2A2520;
  --shadow-warm: 0 1px 0 rgba(31, 27, 23, 0.04), 0 4px 18px -8px rgba(31, 27, 23, 0.18);
  --shadow-deep: 0 2px 0 rgba(31, 27, 23, 0.06), 0 18px 40px -20px rgba(31, 27, 23, 0.28);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  background: var(--paper);
  color: var(--ink);
  font-family: 'Sarabun', 'Noto Serif Thai', serif;
  font-weight: 400;
  font-size: 15px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

body {
  background-image:
    radial-gradient(circle at 12% 8%, rgba(184, 68, 44, 0.04) 0%, transparent 38%),
    radial-gradient(circle at 88% 92%, rgba(61, 92, 58, 0.05) 0%, transparent 42%),
    repeating-linear-gradient(0deg, transparent 0, transparent 32px, rgba(31, 27, 23, 0.012) 32px, rgba(31, 27, 23, 0.012) 33px);
  min-height: 100vh;
  padding: 32px 28px 80px;
}

.serif { font-family: 'Fraunces', 'Noto Serif Thai', serif; }
.thai-display { font-family: 'Noto Serif Thai', 'Fraunces', serif; font-weight: 600; }
.mono { font-family: 'JetBrains Mono', monospace; font-feature-settings: "tnum"; }

.wrap { max-width: 1480px; margin: 0 auto; }

/* ─── MASTHEAD ───────────────────────────────────────────── */
.masthead {
  border-top: 2px solid var(--ink);
  border-bottom: 1px solid var(--ink);
  padding: 14px 0 20px;
  margin-bottom: 32px;
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 32px;
  align-items: end;
}

.masthead .vol {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--ink-mute);
  text-transform: uppercase;
  border-left: 2px solid var(--accent-risk);
  padding-left: 10px;
  align-self: end;
  padding-bottom: 4px;
}

.masthead .title-block { text-align: center; }

.masthead .eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.32em;
  color: var(--ink-mute);
  text-transform: uppercase;
  margin-bottom: 6px;
}

.masthead h1 {
  font-family: 'Fraunces', serif;
  font-weight: 400;
  font-size: clamp(38px, 5vw, 64px);
  letter-spacing: -0.02em;
  line-height: 0.95;
  font-variation-settings: "opsz" 144;
}

.masthead h1 em {
  font-style: italic;
  font-weight: 300;
  color: var(--accent-risk);
}

.masthead .subtitle {
  font-family: 'Noto Serif Thai', serif;
  font-weight: 400;
  font-size: 15px;
  color: var(--ink-soft);
  margin-top: 8px;
  letter-spacing: 0.005em;
}

.masthead .date {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  letter-spacing: 0.18em;
  color: var(--ink-mute);
  text-transform: uppercase;
  text-align: right;
  align-self: end;
  padding-bottom: 4px;
}

.masthead .date strong { color: var(--ink); font-weight: 500; }

/* ─── PROLOGUE ───────────────────────────────────────────── */
.prologue {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 56px;
  padding-bottom: 36px;
  margin-bottom: 36px;
  border-bottom: 1px solid var(--rule);
  align-items: start;
}

.prologue h2 {
  font-family: 'Noto Serif Thai', serif;
  font-weight: 600;
  font-size: 28px;
  line-height: 1.25;
  letter-spacing: -0.005em;
  color: var(--ink);
}

.prologue h2 .accent {
  color: var(--accent-risk);
  font-style: italic;
  font-family: 'Fraunces', serif;
  font-weight: 400;
}

.prologue .lede {
  font-family: 'Noto Serif Thai', serif;
  font-size: 16.5px;
  line-height: 1.7;
  color: var(--ink-soft);
}

.prologue .lede p + p { margin-top: 14px; }

.prologue .lede .dropcap {
  font-family: 'Fraunces', serif;
  font-weight: 400;
  font-size: 56px;
  line-height: 0.8;
  float: left;
  margin: 4px 8px -2px 0;
  color: var(--accent-risk);
}

/* ─── DIMENSION KEY ──────────────────────────────────────── */
.dim-key {
  margin-bottom: 36px;
  padding: 22px 26px;
  background: linear-gradient(180deg, var(--paper-2) 0%, transparent 100%);
  border: 1px solid var(--rule-soft);
  border-radius: 2px;
  position: relative;
}

.dim-key::before {
  content: "C—RADAR";
  position: absolute;
  top: -8px;
  left: 18px;
  background: var(--paper);
  padding: 0 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.32em;
  color: var(--ink-mute);
}

.dim-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 18px;
}

.dim { position: relative; padding-left: 14px; }

.dim::before {
  content: '';
  position: absolute;
  left: 0; top: 4px; bottom: 4px;
  width: 3px;
  background: var(--dim-color, var(--accent-risk));
}

.dim .letter {
  font-family: 'Fraunces', serif;
  font-weight: 400;
  font-size: 38px;
  line-height: 1;
  color: var(--dim-color);
  font-style: italic;
}

.dim .name-en {
  font-family: 'Fraunces', serif;
  font-size: 14px;
  font-weight: 500;
  color: var(--ink);
  margin-top: 4px;
  letter-spacing: -0.005em;
}

.dim .name-th {
  font-family: 'Noto Serif Thai', serif;
  font-size: 13px;
  color: var(--ink-soft);
  margin-top: 2px;
  font-weight: 500;
}

.dim .indicators {
  font-family: 'Sarabun', sans-serif;
  font-size: 11.5px;
  color: var(--ink-mute);
  margin-top: 6px;
  line-height: 1.5;
}

/* ─── KPI STRIP ──────────────────────────────────────────── */
.kpi-strip {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  border-top: 2px solid var(--ink);
  border-bottom: 1px solid var(--ink);
  margin-bottom: 36px;
}

.kpi {
  padding: 18px 20px;
  border-right: 1px solid var(--rule);
  position: relative;
}

.kpi:last-child { border-right: none; }

.kpi .label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9.5px;
  letter-spacing: 0.18em;
  color: var(--ink-mute);
  text-transform: uppercase;
  margin-bottom: 6px;
}

.kpi .value {
  font-family: 'Fraunces', serif;
  font-weight: 400;
  font-size: 34px;
  line-height: 1;
  letter-spacing: -0.02em;
  color: var(--ink);
}

.kpi .unit {
  font-family: 'Sarabun', sans-serif;
  font-size: 13px;
  color: var(--ink-mute);
  margin-left: 4px;
}

.kpi .delta {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  margin-top: 8px;
  color: var(--ink-soft);
}

.kpi .delta.warn { color: var(--accent-risk); }
.kpi .delta.good { color: var(--accent-good); }

/* ─── MAIN GRID ──────────────────────────────────────────── */
.atlas {
  display: grid;
  grid-template-columns: 1.35fr 1fr;
  gap: 28px;
  margin-bottom: 36px;
}

.panel {
  background: var(--paper);
  border: 1px solid var(--rule-soft);
  border-radius: 2px;
  padding: 22px 24px 24px;
  box-shadow: var(--shadow-warm);
  position: relative;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding-bottom: 14px;
  margin-bottom: 18px;
  border-bottom: 1px solid var(--rule-soft);
}

.panel-head h3 {
  font-family: 'Noto Serif Thai', serif;
  font-size: 19px;
  font-weight: 600;
  letter-spacing: -0.005em;
  color: var(--ink);
}

.panel-head h3 .figno {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.2em;
  color: var(--ink-mute);
  text-transform: uppercase;
  margin-right: 10px;
  font-weight: 400;
}

.panel-head .meta {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px;
  color: var(--ink-mute);
  letter-spacing: 0.04em;
}

/* ─── DIMENSION SWITCHER ─────────────────────────────────── */
.dim-switcher {
  display: flex;
  gap: 0;
  margin-bottom: 16px;
  border: 1px solid var(--rule);
  border-radius: 2px;
  overflow: hidden;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
}

.dim-switcher button {
  flex: 1;
  background: var(--paper);
  border: none;
  border-right: 1px solid var(--rule);
  padding: 9px 4px;
  cursor: pointer;
  font-family: inherit;
  font-size: inherit;
  color: var(--ink-soft);
  letter-spacing: 0.06em;
  transition: all 0.18s ease;
  text-transform: uppercase;
}

.dim-switcher button:last-child { border-right: none; }
.dim-switcher button:hover { background: var(--paper-2); color: var(--ink); }
.dim-switcher button.active { background: var(--ink); color: var(--paper); }

.dim-switcher button .ltr {
  font-family: 'Fraunces', serif;
  font-style: italic;
  font-size: 14px;
  font-weight: 400;
  margin-right: 4px;
}

/* ─── MAP ────────────────────────────────────────────────── */
.map-stage {
  position: relative;
  background: linear-gradient(135deg, #F8F3E5 0%, #F0E9D5 100%);
  border: 1px solid var(--rule-soft);
  border-radius: 2px;
  padding: 12px;
  aspect-ratio: 1 / 0.92;
  overflow: hidden;
}

.map-stage::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    repeating-linear-gradient(0deg, transparent 0, transparent 40px, rgba(31, 27, 23, 0.03) 40px, rgba(31, 27, 23, 0.03) 41px),
    repeating-linear-gradient(90deg, transparent 0, transparent 40px, rgba(31, 27, 23, 0.03) 40px, rgba(31, 27, 23, 0.03) 41px);
  pointer-events: none;
}

.map-svg {
  width: 100%;
  height: 100%;
  display: block;
  position: relative;
  z-index: 1;
}

.amphoe-node { cursor: pointer; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); }

.amphoe-node circle.fill {
  stroke: var(--ink);
  stroke-width: 1;
  transition: all 0.25s ease;
}

.amphoe-node:hover circle.fill,
.amphoe-node.selected circle.fill {
  stroke-width: 2.5;
  stroke: var(--ink);
  filter: drop-shadow(0 4px 8px rgba(31, 27, 23, 0.28));
}

.amphoe-node text {
  font-family: 'Sarabun', sans-serif;
  font-size: 8.5px;
  fill: var(--ink-soft);
  text-anchor: middle;
  pointer-events: none;
  font-weight: 500;
}

.amphoe-node.selected text { fill: var(--ink); font-weight: 700; }

.amphoe-node text.label-bg {
  stroke: var(--paper);
  stroke-width: 2.6;
  paint-order: stroke;
}

.map-legend {
  position: absolute;
  bottom: 18px;
  left: 18px;
  background: rgba(246, 242, 233, 0.94);
  backdrop-filter: blur(4px);
  border: 1px solid var(--rule);
  padding: 10px 14px;
  border-radius: 2px;
  z-index: 2;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
}

.map-legend .lg-title {
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: var(--ink-mute);
  margin-bottom: 8px;
}

.legend-bar { display: flex; width: 180px; height: 8px; margin-bottom: 4px; }
.legend-bar div { flex: 1; }

.legend-ticks {
  display: flex;
  justify-content: space-between;
  color: var(--ink-mute);
  font-size: 9.5px;
}

.map-compass {
  position: absolute;
  top: 18px;
  right: 18px;
  width: 38px;
  height: 38px;
  z-index: 2;
  opacity: 0.5;
}

.map-scale {
  position: absolute;
  bottom: 18px;
  right: 18px;
  z-index: 2;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9.5px;
  color: var(--ink-mute);
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 2px;
}

.scale-bar {
  width: 60px;
  height: 4px;
  background: linear-gradient(90deg, var(--ink) 0%, var(--ink) 50%, var(--paper) 50%, var(--paper) 100%);
  border: 1px solid var(--ink);
}

/* ─── DETAIL PANEL ───────────────────────────────────────── */
.detail-stack { display: flex; flex-direction: column; gap: 22px; }

.amphoe-card {
  border: 1px solid var(--rule-soft);
  background: var(--paper);
  padding: 20px 22px;
  border-radius: 2px;
}

.amphoe-card .label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.22em;
  color: var(--ink-mute);
  text-transform: uppercase;
  margin-bottom: 4px;
}

.amphoe-card .name {
  font-family: 'Noto Serif Thai', serif;
  font-size: 30px;
  font-weight: 600;
  letter-spacing: -0.01em;
  color: var(--ink);
  line-height: 1.05;
}

.amphoe-card .name-en {
  font-family: 'Fraunces', serif;
  font-style: italic;
  font-size: 16px;
  color: var(--ink-mute);
  font-weight: 400;
  margin-top: 2px;
}

.amphoe-stats {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16px;
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid var(--rule-soft);
}

.amphoe-stat .lbl {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9.5px;
  letter-spacing: 0.14em;
  color: var(--ink-mute);
  text-transform: uppercase;
}

.amphoe-stat .val {
  font-family: 'Fraunces', serif;
  font-size: 22px;
  font-weight: 500;
  color: var(--ink);
  margin-top: 2px;
  letter-spacing: -0.01em;
}

.amphoe-stat .val .small {
  font-family: 'Sarabun', sans-serif;
  font-size: 11px;
  font-weight: 400;
  color: var(--ink-mute);
  margin-left: 2px;
}

/* ─── RADAR CHART ────────────────────────────────────────── */
.radar-stage {
  background: linear-gradient(180deg, #F8F4E8 0%, #F2EBD8 100%);
  border: 1px solid var(--rule-soft);
  padding: 16px;
  position: relative;
  aspect-ratio: 1 / 1;
}

.radar-svg { width: 100%; height: 100%; display: block; }

.radar-grid line, .radar-grid polygon {
  fill: none;
  stroke: var(--rule);
  stroke-width: 0.5;
}

.radar-grid polygon.outer {
  stroke: var(--ink-mute);
  stroke-width: 1;
  fill: rgba(246, 242, 233, 0.4);
}

.radar-data {
  fill: rgba(184, 68, 44, 0.14);
  stroke: var(--accent-risk);
  stroke-width: 1.8;
  stroke-linejoin: round;
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.radar-data-compare {
  fill: rgba(61, 92, 58, 0.08);
  stroke: var(--accent-good);
  stroke-width: 1.5;
  stroke-dasharray: 4 3;
}

.radar-point {
  fill: var(--accent-risk);
  stroke: var(--paper);
  stroke-width: 1.5;
  transition: all 0.3s ease;
}

.radar-label {
  font-family: 'Fraunces', serif;
  font-size: 14px;
  font-style: italic;
  font-weight: 500;
}

.radar-label-th {
  font-family: 'Noto Serif Thai', serif;
  font-size: 10.5px;
  fill: var(--ink-mute);
  font-weight: 500;
}

.radar-tick {
  font-family: 'JetBrains Mono', monospace;
  font-size: 8.5px;
  fill: var(--ink-mute);
}

.radar-pattern-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px;
  letter-spacing: 0.22em;
  color: var(--ink-mute);
  text-transform: uppercase;
  margin-top: 14px;
  padding-top: 12px;
  border-top: 1px dashed var(--rule);
}

.radar-pattern-tag strong {
  color: var(--accent-risk);
  font-weight: 500;
  letter-spacing: 0.02em;
  text-transform: none;
  font-size: 13px;
  display: block;
  font-family: 'Noto Serif Thai', serif;
  margin-top: 4px;
}

/* ─── ANALYSIS GRID ──────────────────────────────────────── */
.analysis-grid {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 28px;
  margin-bottom: 36px;
}

.rank-table { width: 100%; border-collapse: collapse; font-size: 13px; }

.rank-table thead th {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9.5px;
  letter-spacing: 0.18em;
  color: var(--ink-mute);
  text-transform: uppercase;
  text-align: left;
  padding: 8px 8px 10px;
  border-bottom: 2px solid var(--ink);
  font-weight: 400;
}

.rank-table thead th.num { text-align: right; }

.rank-table tbody tr {
  border-bottom: 1px solid var(--rule-soft);
  cursor: pointer;
  transition: background 0.15s ease;
}

.rank-table tbody tr:hover { background: var(--paper-2); }
.rank-table tbody tr.selected { background: rgba(184, 68, 44, 0.06); }

.rank-table tbody td { padding: 9px 8px; vertical-align: middle; }

.rank-table td.rank {
  font-family: 'Fraunces', serif;
  font-style: italic;
  color: var(--ink-mute);
  width: 32px;
}

.rank-table td.name-cell {
  font-family: 'Noto Serif Thai', serif;
  font-weight: 500;
  color: var(--ink);
}

.rank-table td.num {
  font-family: 'JetBrains Mono', monospace;
  text-align: right;
  color: var(--ink-soft);
}

.bar-cell { width: 90px; }

.mini-bar {
  height: 6px;
  background: var(--rule-soft);
  border-radius: 1px;
  overflow: hidden;
}

.mini-bar .fill { height: 100%; transition: width 0.4s ease; }

.tier-pill {
  display: inline-block;
  padding: 2px 8px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9.5px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  border-radius: 1px;
  font-weight: 500;
}

.tier-pill.critical { background: rgba(184, 68, 44, 0.16); color: var(--accent-risk); }
.tier-pill.high { background: rgba(194, 138, 44, 0.16); color: #946716; }
.tier-pill.moderate { background: rgba(138, 122, 58, 0.14); color: var(--accent-mid); }
.tier-pill.low { background: rgba(61, 92, 58, 0.14); color: var(--accent-good); }

.rank-scroll { max-height: 620px; overflow-y: auto; }
.rank-scroll::-webkit-scrollbar { width: 6px; }
.rank-scroll::-webkit-scrollbar-thumb { background: var(--rule); border-radius: 3px; }

.archetype-list { display: flex; flex-direction: column; gap: 14px; }

.archetype {
  border-left: 3px solid var(--arch-color, var(--accent-risk));
  padding: 12px 16px 12px 18px;
  background: linear-gradient(90deg, rgba(0,0,0,0.015), transparent);
}

.archetype .arch-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 4px;
}

.archetype .arch-name {
  font-family: 'Noto Serif Thai', serif;
  font-weight: 600;
  font-size: 15.5px;
  color: var(--ink);
}

.archetype .arch-name-en {
  font-family: 'Fraunces', serif;
  font-style: italic;
  font-size: 12px;
  color: var(--ink-mute);
}

.archetype .arch-count {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  color: var(--ink-mute);
}

.archetype .arch-desc {
  font-size: 13px;
  color: var(--ink-soft);
  line-height: 1.55;
  margin-top: 4px;
}

.archetype .arch-intervention {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px;
  letter-spacing: 0.05em;
  color: var(--arch-color, var(--accent-risk));
  margin-top: 8px;
  text-transform: uppercase;
}

/* ─── RESEARCH PATHWAYS ──────────────────────────────────── */
.research-section {
  border-top: 2px solid var(--ink);
