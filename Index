DATA.forEach(d => {
  d.composite = Math.round((d.C + d.R1 + d.A1 + d.D + d.A2 + d.R2) / 6);
  d.tier = d.composite < 50 ? 'critical' : d.composite < 58 ? 'high' : d.composite < 66 ? 'moderate' : 'low';
});

const PROV = ['C','R1','A1','D','A2','R2'].reduce((a,k) => (a[k] = Math.round(DATA.reduce((s,d)=>s+d[k],0)/DATA.length), a), {});

function colorScale(v) {
  if (v < 45) return '#B8442C';
  if (v < 54) return '#C28A2C';
  if (v < 62) return '#8A7A3A';
  if (v < 70) return '#6B8A5C';
  return '#3D5C3A';
}

const maxElderly = Math.max(...DATA.map(d => d.elderly));
function radiusScale(elderly) {
  return 7 + Math.sqrt(elderly / maxElderly) * 20;
}

const DIM_META = {
  composite: { name: 'Composite C-RADAR', th: 'ดัชนีรวม', color: '#1F1B17' },
  C: { name: 'Community Vitality', th: 'ชีวิตชีวาของชุมชน', color: '#B8442C' },
  R1: { name: 'Risk Burden', th: 'ภาระความเสี่ยง', color: '#C28A2C' },
  A1: { name: 'Access to Care', th: 'การเข้าถึงบริการ', color: '#8A7A3A' },
  D: { name: 'Demographic Pressure', th: 'แรงกดดันประชากร', color: '#6B8A5C' },
  A2: { name: 'Adaptive Capacity', th: 'ความสามารถปรับตัว', color: '#3D5C3A' },
  R2: { name: 'Resource Ecosystem', th: 'ระบบนิเวศทรัพยากร', color: '#2E3B2D' },
};

let currentDim = 'composite';
let selectedId = 'nm01';

const mapSvg = document.getElementById('mapSvg');

function drawMap() {
  mapSvg.innerHTML = '';

  const frame = `
    <defs>
      <pattern id="topo" x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="0.4" fill="rgba(31, 27, 23, 0.08)"/>
      </pattern>
      <radialGradient id="provinceBg" cx="50%" cy="50%" r="60%">
        <stop offset="0%" stop-color="rgba(255,255,255,0.4)"/>
        <stop offset="100%" stop-color="rgba(184, 138, 44, 0.05)"/>
      </radialGradient>
    </defs>
    <path d="M 60 90 Q 90 55, 160 70 Q 230 50, 300 62 Q 380 48, 450 72 Q 520 62, 555 110 Q 570 175, 550 245 Q 565 320, 535 390 Q 555 450, 500 495 Q 430 520, 360 508 Q 290 520, 220 500 Q 150 512, 95 480 Q 55 435, 55 365 Q 40 290, 55 220 Q 38 150, 60 90 Z"
      fill="url(#provinceBg)" stroke="rgba(31, 27, 23, 0.35)" stroke-width="1.2" stroke-linejoin="round"/>
    <path d="M 60 90 Q 90 55, 160 70 Q 230 50, 300 62 Q 380 48, 450 72 Q 520 62, 555 110 Q 570 175, 550 245 Q 565 320, 535 390 Q 555 450, 500 495 Q 430 520, 360 508 Q 290 520, 220 500 Q 150 512, 95 480 Q 55 435, 55 365 Q 40 290, 55 220 Q 38 150, 60 90 Z"
      fill="url(#topo)" stroke="none" opacity="0.6"/>
    <text x="555" y="52" text-anchor="end" font-family="Fraunces, serif" font-style="italic" font-size="13" fill="rgba(31, 27, 23, 0.4)">Nakhon Ratchasima</text>
    <text x="555" y="67" text-anchor="end" font-family="Noto Serif Thai, serif" font-size="10" fill="rgba(31, 27, 23, 0.35)">จังหวัดนครราชสีมา · 32 อำเภอ</text>
  `;
  mapSvg.insertAdjacentHTML('beforeend', frame);

  const center = DATA.find(d => d.id === 'nm01');
  DATA.forEach(d => {
    if (d.id === 'nm01') return;
    const dist = Math.hypot(d.x - center.x, d.y - center.y);
    if (dist < 90) {
      mapSvg.insertAdjacentHTML('beforeend',
        `<line x1="${center.x}" y1="${center.y}" x2="${d.x}" y2="${d.y}" stroke="rgba(31, 27, 23, 0.07)" stroke-width="0.5" stroke-dasharray="2 3"/>`);
    }
  });

  DATA.forEach(d => {
    const v = d[currentDim] !== undefined ? d[currentDim] : d.composite;
    const r = radiusScale(d.elderly);
    const isSelected = d.id === selectedId;

    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.setAttribute('class', 'amphoe-node' + (isSelected ? ' selected' : ''));
    g.setAttribute('transform', `translate(${d.x}, ${d.y})`);
    g.setAttribute('data-id', d.id);

    if (isSelected) {
      g.insertAdjacentHTML('beforeend',
        `<circle r="${r + 7}" fill="none" stroke="${colorScale(v)}" stroke-width="1" stroke-dasharray="3 2" opacity="0.5"/>`);
    }

    g.insertAdjacentHTML('beforeend',
      `<circle class="fill" r="${r}" fill="${colorScale(v)}" fill-opacity="0.78"/>`);

    if (r > 13) {
      g.insertAdjacentHTML('beforeend',
        `<text y="3" font-family="Fraunces, serif" font-weight="500" font-size="${r * 0.68}" fill="#F6F2E9" text-anchor="middle">${v}</text>`);
    }

    g.insertAdjacentHTML('beforeend', `<text class="label-bg" y="${r + 10}">${d.th}</text>`);
    g.insertAdjacentHTML('beforeend', `<text y="${r + 10}">${d.th}</text>`);

    g.addEventListener('click', () => { selectedId = d.id; render(); });
    mapSvg.appendChild(g);
  });
}

const radarSvg = document.getElementById('radarSvg');

function drawRadar() {
  radarSvg.innerHTML = '';
  const cx = 200, cy = 200, maxR = 130;
  const dims = ['C','R1','A1','D','A2','R2'];
  const labels = {
    C: { en: 'Community', th: 'ชุมชน', color: '#B8442C' },
    R1: { en: 'Risk', th: 'ความเสี่ยง', color: '#C28A2C' },
    A1: { en: 'Access', th: 'การเข้าถึง', color: '#8A7A3A' },
    D: { en: 'Demo', th: 'ประชากร', color: '#6B8A5C' },
    A2: { en: 'Adapt', th: 'ปรับตัว', color: '#3D5C3A' },
    R2: { en: 'Resource', th: 'ทรัพยากร', color: '#2E3B2D' },
  };
  const sel = DATA.find(d => d.id === selectedId);

  const gridGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
  gridGroup.setAttribute('class', 'radar-grid');
  for (let pct = 25; pct <= 100; pct += 25) {
    const r = (maxR * pct) / 100;
    const points = dims.map((_, i) => {
      const angle = (i * Math.PI * 2 / 6) - Math.PI / 2;
      return `${cx + Math.cos(angle) * r},${cy + Math.sin(angle) * r}`;
    }).join(' ');
    gridGroup.insertAdjacentHTML('beforeend', `<polygon points="${points}" class="${pct === 100 ? 'outer' : ''}"/>`);
  }
  dims.forEach((_, i) => {
    const angle = (i * Math.PI * 2 / 6) - Math.PI / 2;
    gridGroup.insertAdjacentHTML('beforeend',
      `<line x1="${cx}" y1="${cy}" x2="${cx + Math.cos(angle) * maxR}" y2="${cy + Math.sin(angle) * maxR}"/>`);
  });
  [25, 50, 75].forEach(t => {
    const r = (maxR * t) / 100;
    gridGroup.insertAdjacentHTML('beforeend', `<text class="radar-tick" x="${cx + 3}" y="${cy - r + 3}">${t}</text>`);
  });
  radarSvg.appendChild(gridGroup);

  const provPoints = dims.map((k, i) => {
    const angle = (i * Math.PI * 2 / 6) - Math.PI / 2;
    const r = (maxR * PROV[k]) / 100;
    return `${cx + Math.cos(angle) * r},${cy + Math.sin(angle) * r}`;
  }).join(' ');
  radarSvg.insertAdjacentHTML('beforeend', `<polygon class="radar-data-compare" points="${provPoints}"/>`);

  const selPointsArr = dims.map((k, i) => {
    const angle = (i * Math.PI * 2 / 6) - Math.PI / 2;
    const r = (maxR * sel[k]) / 100;
    return { x: cx + Math.cos(angle) * r, y: cy + Math.sin(angle) * r, k, val: sel[k] };
  });
  radarSvg.insertAdjacentHTML('beforeend', `<polygon class="radar-data" points="${selPointsArr.map(p => `${p.x},${p.y}`).join(' ')}"/>`);

  selPointsArr.forEach(p => {
    radarSvg.insertAdjacentHTML('beforeend', `<circle class="radar-point" cx="${p.x}" cy="${p.y}" r="4.5" fill="${labels[p.k].color}"/>`);
    radarSvg.insertAdjacentHTML('beforeend', `<text class="radar-tick" x="${p.x}" y="${p.y - 11}" text-anchor="middle" font-weight="600" fill="#1F1B17" font-size="10">${p.val}</text>`);
  });

  dims.forEach((k, i) => {
    const angle = (i * Math.PI * 2 / 6) - Math.PI / 2;
    const lx = cx + Math.cos(angle) * (maxR + 32);
    const ly = cy + Math.sin(angle) * (maxR + 32);
    radarSvg.insertAdjacentHTML('beforeend', `<text class="radar-label" x="${lx}" y="${ly}" text-anchor="middle" dominant-baseline="middle" fill="${labels[k].color}">${labels[k].en}</text>`);
    radarSvg.insertAdjacentHTML('beforeend', `<text class="radar-label-th" x="${lx}" y="${ly + 13}" text-anchor="middle" dominant-baseline="middle">${labels[k].th}</text>`);
  });
  radarSvg.insertAdjacentHTML('beforeend', `<circle cx="${cx}" cy="${cy}" r="2" fill="#1F1B17"/>`);
}

function classifyArchetype(d) {
  if (d.A1 > 72 && d.C < 64 && d.A2 < 68) return { name: 'ผู้สูงวัยลำพังในเมือง', en: 'Isolated Urban Elderly', color: '#B8442C', key: 'IUE' };
  if (d.A1 < 55 && d.R2 < 58 && d.C > 68) return { name: 'ชนบทขาดบริการ', en: 'Rural Service Desert', color: '#C28A2C', key: 'RSD' };
  if (d.D < 58 && d.A2 < 58) return { name: 'บุตรหลานไปทำงาน', en: 'Skipped-Generation', color: '#8A7A3A', key: 'SG' };
  if (d.composite > 62) return { name: 'ชุมชนเข้มแข็งครบเครื่อง', en: 'Resilient Multi-Gen', color: '#3D5C3A', key: 'RMG' };
  return { name: 'ผสมหลายรูปแบบ', en: 'Mixed Profile', color: '#6B8A5C', key: 'MIX' };
}

function drawAmphoeCard() {
  const d = DATA.find(x => x.id === selectedId);
  const card = document.getElementById('amphoeCard');
  const arch = classifyArchetype(d);
  const elderlyPct = ((d.elderly / d.pop) * 100).toFixed(1);

  card.innerHTML = `
    <div class="label">District profile · ${d.id.toUpperCase()}</div>
    <div class="name">อำเภอ${d.th}</div>
    <div class="name-en">${d.en}</div>
    <div class="amphoe-stats">
      <div class="amphoe-stat">
        <div class="lbl">ผู้สูงอายุ Elderly</div>
        <div class="val">${d.elderly.toLocaleString()}<span class="small">คน · ${elderlyPct}%</span></div>
      </div>
      <div class="amphoe-stat">
        <div class="lbl">C-RADAR Score</div>
        <div class="val" style="color:${colorScale(d.composite)}">${d.composite}<span class="small">/100</span></div>
      </div>
      <div class="amphoe-stat">
        <div class="lbl">Tier · ระดับ</div>
        <div class="val"><span class="tier-pill ${d.tier}">${d.tier}</span></div>
      </div>
    </div>
  `;
  document.getElementById('patternName').textContent = `${arch.name} · ${arch.en}`;
  document.getElementById('patternName').style.color = arch.color;
}

function drawRankTable() {
  const sorted = [...DATA].sort((a,b) => a.composite - b.composite);
  const tbody = document.getElementById('rankBody');
  tbody.innerHTML = sorted.map((d, i) => {
    const arch = classifyArchetype(d);
    const isSel = d.id === selectedId;
    return `
      <tr class="${isSel ? 'selected' : ''}" data-id="${d.id}">
        <td class="rank">${(i + 1).toString().padStart(2, '0')}</td>
        <td class="name-cell">${d.th}</td>
        <td class="num">${d.elderly.toLocaleString()}</td>
        <td class="num bar-cell">
          <div style="display:flex; align-items:center; gap:8px; justify-content:flex-end;">
            <span>${d.composite}</span>
            <div class="mini-bar" style="flex:1; max-width:52px;">
              <div class="fill" style="width:${d.composite}%; background:${colorScale(d.composite)}"></div>
            </div>
          </div>
        </td>
        <td class="num" style="font-family:'Noto Serif Thai',serif; font-size:11px; color:${arch.color}">${arch.en}</td>
        <td><span class="tier-pill ${d.tier}">${d.tier}</span></td>
      </tr>
    `;
  }).join('');
  tbody.querySelectorAll('tr').forEach(tr => {
    tr.addEventListener('click', () => { selectedId = tr.dataset.id; render(); });
  });
}

function drawArchetypes() {
  const archs = [
    { key: 'IUE', color: '#B8442C', th: 'ผู้สูงวัยลำพังในเมือง', en: 'Isolated Urban Elderly',
      desc: 'access ดี แต่ <em>community</em> และ <em>adaptive</em> ต่ำ — ผู้สูงอายุอยู่คนเดียว, ความสัมพันธ์เพื่อนบ้านบาง',
      action: '→ befriending · digital companion intervention' },
    { key: 'RSD', color: '#C28A2C', th: 'ชนบทขาดบริการ', en: 'Rural Service Desert',
      desc: '<em>community</em> เหนียวแน่น แต่ <em>access</em> วิกฤต — ระยะทาง รพช.ไกล, ขาด specialist',
      action: '→ mobile clinic · telemedicine · อสม.empowerment' },
    { key: 'SG', color: '#8A7A3A', th: 'บุตรหลานไปทำงาน', en: 'Skipped-Generation',
      desc: 'วัยลูกย้ายไปทำงานเมือง เหลือผู้สูงอายุดูแลหลาน — <em>demographic</em> กดดัน, double burden',
      action: '→ family cash transfer · community day-care' },
    { key: 'RMG', color: '#3D5C3A', th: 'ชุมชนเข้มแข็งครบเครื่อง', en: 'Resilient Multi-Gen',
      desc: 'ทั้ง 6 มิติบาลานซ์ดี — ครอบครัวขยาย, ชมรมแอ็คทีฟ — <strong>learning sites สำหรับ scale-up</strong>',
      action: '→ knowledge hub · positive deviance research' },
  ];
  const listEl = document.getElementById('archetypeList');
  listEl.innerHTML = archs.map(a => {
    const count = DATA.filter(d => classifyArchetype(d).key === a.key).length;
    const pct = Math.round(count / DATA.length * 100);
    return `
      <div class="archetype" style="--arch-color: ${a.color};">
        <div class="arch-head">
          <div>
            <div class="arch-name">${a.th}</div>
            <div class="arch-name-en">${a.en}</div>
          </div>
          <div class="arch-count">n=${count} · ${pct}%</div>
        </div>
        <div class="arch-desc">${a.desc}</div>
        <div class="arch-intervention">${a.action}</div>
      </div>
    `;
  }).join('');
}

const dimButtons = document.querySelectorAll('#dimSwitcher button');
dimButtons.forEach(btn => {
  btn.addEventListener('click', () => {
    currentDim = btn.dataset.dim;
    dimButtons.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const meta = DIM_META[currentDim];
    document.getElementById('mapMeta').textContent = `view by ${meta.name.toLowerCase()}`;
    document.getElementById('legendTitle').textContent = meta.name;
    drawMap();
  });
});

function render() {
  drawMap();
  drawRadar();
  drawAmphoeCard();
  drawRankTable();
  const sel = DATA.find(d => d.id === selectedId);
  document.getElementById('radarMeta').textContent = `${sel.th} vs province avg`;
}

render();
drawArchetypes();

document.querySelectorAll('.panel, .kpi, .dim').forEach((el, i) => {
  el.style.animationDelay = (i * 0.03) + 's';
  el.classList.add('fade-in');
});
</script>
